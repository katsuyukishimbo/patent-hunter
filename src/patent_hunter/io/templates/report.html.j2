<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>Patent Hunter — {{ week_label }}</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
<style>
  body { padding: 2rem; }
  td.plain { max-width: 28rem; }
  td.signal { max-width: 18rem; font-size: 0.9rem; color: #555; }
  .badge-adopted { background: #198754; }
  .badge-shortlist { background: #6c757d; }
  .small-meta { font-size: 0.85rem; color: #555; }
  code.pid { font-size: 0.95rem; }
</style>
</head>
<body>
<div class="container-fluid">
  <h1 class="mb-1">Patent Hunter — {{ week_label }}</h1>
  <p class="small-meta">
    fetched <strong>{{ stats.fetched }}</strong> ·
    scored <strong>{{ stats.scored }}</strong> ·
    adopted (both ≥ {{ score_threshold }}) <strong>{{ stats.adopted }}</strong> ·
    cost ~ <strong>${{ "%.4f"|format(stats.total_cost_usd) }}</strong>
    (Sonnet ${{ "%.4f"|format(stats.sonnet_cost_usd) }} +
     Codex ${{ "%.4f"|format(stats.codex_cost_usd_estimate) }})
    · {{ stats.started_at }} → {{ stats.ended_at }}
  </p>

  {% if stats.errors %}
  <div class="alert alert-warning">
    <strong>Warnings:</strong>
    <ul class="mb-0">
      {% for e in stats.errors %}<li>{{ e }}</li>{% endfor %}
    </ul>
  </div>
  {% endif %}

  {% if not top %}
    <p class="text-muted">No patents passed scoring this week.</p>
  {% else %}
  <table class="table table-striped table-hover align-top">
    <thead>
      <tr>
        <th>#</th>
        <th>Patent</th>
        <th>Category</th>
        <th class="plain">Plain English</th>
        <th>BOM</th>
        <th>Amazon gap</th>
        <th class="signal">Review signal</th>
        <th>Sonnet</th>
        <th>Codex</th>
        <th>Consensus</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      {% for sp in top %}
      <tr>
        <td>{{ loop.index }}</td>
        <td>
          <a href="{{ sp.patent.google_patents_url }}" target="_blank" rel="noreferrer">
            <code class="pid">US{{ sp.patent.patent_id }}</code>
          </a>
          <div class="small-meta">{{ sp.patent.title }}</div>
          <div class="small-meta">granted {{ sp.patent.grant_date }} · CPC {{ sp.patent.cpc_code }}</div>
          {% if sp.patent.assignee_name %}
          <div class="small-meta">assignee: {{ sp.patent.assignee_name }}</div>
          {% endif %}
        </td>
        <td><span class="badge bg-secondary">{{ sp.patent.category }}</span></td>
        <td class="plain">{{ sp.sonnet.plain_english or sp.codex.plain_english or "—" }}</td>
        <td>{{ sp.sonnet.bom_estimate or sp.codex.bom_estimate or "—" }}</td>
        <td>
          {% set sg = sp.sonnet.amazon_gap %}
          {% set cg = sp.codex.amazon_gap %}
          {% if sg and cg %}<span class="badge bg-success">yes (both)</span>
          {% elif sg or cg %}<span class="badge bg-warning text-dark">partial</span>
          {% else %}<span class="badge bg-secondary">no</span>{% endif %}
        </td>
        <td class="signal">{{ sp.sonnet.review_signal or sp.codex.review_signal or "—" }}</td>
        <td>{{ sp.sonnet.score }}{% if sp.sonnet.error %} <span class="small-meta">(err)</span>{% endif %}</td>
        <td>{{ sp.codex.score }}{% if sp.codex.error %} <span class="small-meta">(err)</span>{% endif %}</td>
        <td><strong>{{ "%.1f"|format(sp.consensus_score) }}</strong></td>
        <td>
          {% if sp.adopted %}
            <span class="badge badge-adopted">ADOPTED</span>
          {% else %}
            <span class="badge badge-shortlist">shortlist</span>
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <p class="small-meta mt-4">
    Adopted = both Sonnet and Codex returned score ≥ {{ score_threshold }} (Clean Context for Verifier).
    Raw scores in <code>scores.jsonl</code>; run metadata in <code>run.log</code>.
  </p>
</div>
</body>
</html>
