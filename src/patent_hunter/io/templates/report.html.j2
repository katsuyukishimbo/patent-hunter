<!doctype html>
<html lang="ja">
<head>
<meta charset="utf-8" />
<title>Patent Hunter — {{ week_label }}</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
<style>
  body { padding: 2rem; }
  td.summary { max-width: 30rem; }
  td.signal { max-width: 18rem; font-size: 0.9rem; color: #555; }
  .badge-adopted { background: #198754; }
  .badge-shortlist { background: #6c757d; }
  .badge-diy { background: #0d6efd; }
  .confidence { min-width: 9rem; }
  .failure-list { font-size: 0.92rem; }
  .small-meta { font-size: 0.85rem; color: #555; }
  .next-steps { font-size: 0.92rem; }
  .next-steps ol { padding-left: 1.25rem; }
  code.pid { font-size: 0.95rem; }
</style>
</head>
<body>
<div class="container-fluid">
  <h1 class="mb-1">Patent Hunter — {{ week_label }}</h1>
  <p class="small-meta">
    取得 <strong>{{ stats.fetched }}</strong> ·
    採点 <strong>{{ stats.scored }}</strong> ·
    採用 (両モデル ≥ {{ score_threshold }}) <strong>{{ stats.adopted }}</strong> ·
    {% if min_confidence %}信頼度 ≥ {{ min_confidence }}% ·{% endif %}
    {% if diy_only %}DIY モード ·{% endif %}
    費用 ~ <strong>${{ "%.4f"|format(stats.total_cost_usd) }}</strong>
    (Sonnet ${{ "%.4f"|format(stats.sonnet_cost_usd) }} +
     Codex ${{ "%.4f"|format(stats.codex_cost_usd_estimate) }})
    · {{ stats.started_at }} → {{ stats.ended_at }}
  </p>

  {% if stats.errors %}
  <div class="alert alert-warning">
    <strong>Warnings:</strong>
    <ul class="mb-0">
      {% for e in stats.errors %}<li>{{ e }}</li>{% endfor %}
    </ul>
  </div>
  {% endif %}

  {% if not top %}
    <p class="text-muted">今週は採用条件を満たす特許がありませんでした。</p>
  {% else %}
  <table class="table table-striped table-hover align-top">
    <thead>
      <tr>
        <th>#</th>
        <th>特許</th>
        <th>カテゴリ</th>
        <th class="summary">日本語サマリ</th>
        <th>BOM</th>
        <th>Amazon 機会</th>
        <th>DIY</th>
        <th class="confidence">信頼度</th>
        <th class="signal">レビュー不満</th>
        <th>Sonnet</th>
        <th>Codex</th>
        <th>合意</th>
        <th>状態</th>
      </tr>
    </thead>
    <tbody>
      {% for sp in top %}
      {% set short_title = sp.sonnet.short_title_ja or sp.codex.short_title_ja or sp.patent.title %}
      {% set summary = sp.sonnet.summary_ja or sp.codex.summary_ja or sp.sonnet.plain_english or sp.codex.plain_english %}
      {% set opportunity = sp.sonnet.opportunity_ja or sp.codex.opportunity_ja %}
      {% set diy = sp.sonnet if sp.sonnet.diy_friendly else sp.codex %}
      {% set next_steps = sp.sonnet.next_action_steps_ja or sp.codex.next_action_steps_ja %}
      {% set failure_source = sp.sonnet if sp.sonnet.failure_reasons_ja else sp.codex %}
      {% set failure_reasons = failure_source.failure_reasons_ja %}
      {% set failure_mitigations = failure_source.failure_mitigations_ja %}
      {% set collapse_id = "failures-" ~ loop.index %}
      <tr>
        <td>{{ loop.index }}</td>
        <td>
          <a href="{{ sp.patent.google_patents_url }}" target="_blank" rel="noreferrer">
            <code class="pid">{% if sp.patent.patent_id.startswith("US") %}{{ sp.patent.patent_id }}{% else %}US{{ sp.patent.patent_id }}{% endif %}</code>
          </a>
          <div><strong>{{ short_title }}</strong></div>
          <div class="small-meta">{{ sp.patent.title }}</div>
          <div class="small-meta">公開 {{ sp.patent.grant_date }} · CPC {{ sp.patent.cpc_code }}</div>
          {% if sp.patent.assignee_name %}
          <div class="small-meta">権利者: {{ sp.patent.assignee_name }}</div>
          {% endif %}
        </td>
        <td><span class="badge bg-secondary">{{ sp.patent.category }}</span></td>
        <td class="summary">
          {{ summary or "—" }}
          {% if opportunity %}<div class="small-meta">💡 {{ opportunity }}</div>{% endif %}
        </td>
        <td>{{ sp.sonnet.bom_estimate or sp.codex.bom_estimate or "—" }}</td>
        <td>
          {% set sg = sp.sonnet.amazon_gap %}
          {% set cg = sp.codex.amazon_gap %}
          {% if sg and cg %}<span class="badge bg-success">あり (両方)</span>
          {% elif sg or cg %}<span class="badge bg-warning text-dark">片方のみ</span>
          {% else %}<span class="badge bg-secondary">なし</span>{% endif %}
        </td>
        <td>
          {% if diy.diy_friendly %}
            <span class="badge badge-diy">🔧 3DプリントOK</span>
            <div class="small-meta">
              {{ diy.diy_print_minutes or "?" }}分 · ¥{{ diy.diy_material_cost_jpy or "?" }}
              {% if diy.diy_score %} · DIY {{ diy.diy_score }}/10{% endif %}
            </div>
            {% if diy.diy_required_extras %}
              <div class="small-meta">追加: {{ diy.diy_required_extras|join(", ") }}</div>
            {% endif %}
          {% else %}
            <span class="badge bg-secondary">対象外</span>
          {% endif %}
        </td>
        <td class="confidence">
          <div class="small-meta">
            Sonnet:
            score {{ (sp.sonnet.confidence_score ~ "%") if sp.sonnet.confidence_score is not none else "?" }}
            / BOM {{ (sp.sonnet.confidence_bom ~ "%") if sp.sonnet.confidence_bom is not none else "?" }}
            / gap {{ (sp.sonnet.confidence_amazon_gap ~ "%") if sp.sonnet.confidence_amazon_gap is not none else "?" }}
          </div>
          <div class="small-meta">
            Codex:
            score {{ (sp.codex.confidence_score ~ "%") if sp.codex.confidence_score is not none else "?" }}
            / BOM {{ (sp.codex.confidence_bom ~ "%") if sp.codex.confidence_bom is not none else "?" }}
            / gap {{ (sp.codex.confidence_amazon_gap ~ "%") if sp.codex.confidence_amazon_gap is not none else "?" }}
          </div>
          {% if failure_reasons %}
          <button class="btn btn-sm btn-outline-secondary mt-1" type="button" data-bs-toggle="collapse" data-bs-target="#{{ collapse_id }}" aria-expanded="false" aria-controls="{{ collapse_id }}">
            失敗想定
          </button>
          {% endif %}
        </td>
        <td class="signal">{{ sp.sonnet.review_signal or sp.codex.review_signal or "—" }}</td>
        <td>{{ sp.sonnet.score }}{% if sp.sonnet.error %} <span class="small-meta">(err)</span>{% endif %}</td>
        <td>{{ sp.codex.score }}{% if sp.codex.error %} <span class="small-meta">(err)</span>{% endif %}</td>
        <td><strong>{{ "%.1f"|format(sp.consensus_score) }}</strong></td>
        <td>
          {% if sp.adopted %}
            <span class="badge badge-adopted">採用</span>
          {% else %}
            <span class="badge badge-shortlist">候補</span>
          {% endif %}
        </td>
      </tr>
      {% if failure_reasons %}
      <tr class="table-warning">
        <td></td>
        <td colspan="12">
          <div class="collapse" id="{{ collapse_id }}">
            <div class="failure-list">
              <strong>⚠️ 失敗想定と回避策</strong>
              <ol class="mb-0 mt-1">
                {% for reason in failure_reasons[:5] %}
                <li>
                  {{ reason }}
                  {% if failure_mitigations|length >= loop.index %}
                    <div class="small-meta">回避策: {{ failure_mitigations[loop.index0] }}</div>
                  {% endif %}
                </li>
                {% endfor %}
              </ol>
            </div>
          </div>
        </td>
      </tr>
      {% endif %}
      {% if next_steps %}
      <tr class="table-light">
        <td></td>
        <td colspan="12">
          <div class="next-steps">
            <strong>🚀 次の一歩</strong>
            <ol class="mb-0 mt-1">
              {% for step in next_steps[:3] %}
              <li>{{ step }}</li>
              {% endfor %}
            </ol>
          </div>
        </td>
      </tr>
      {% endif %}
      {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <p class="small-meta mt-4">
    採用 = Sonnet と Codex の両方が score ≥ {{ score_threshold }} を返したもの。
    {% if min_confidence %}confidence_score ≥ {{ min_confidence }}% も必要。{% endif %}
    Raw scores は <code>scores.jsonl</code>、run metadata は <code>run.log</code>。
  </p>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
