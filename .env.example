# Required: Anthropic API key for Sonnet scoring
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# Anthropic model id used for scoring. Defaults to claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Codex CLI binary (must be on PATH). Defaults to "codex".
CODEX_BIN=codex

# Codex sandbox. workspace-write is enough because we only read/write inside out/.
CODEX_SANDBOX=workspace-write

# Maximum patents to fetch per category before scoring (cost guard).
MAX_PATENTS_PER_CATEGORY=25

# Score threshold for "both models agree" cut.
SCORE_THRESHOLD=7
