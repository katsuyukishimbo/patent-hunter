# Required for live BigQuery fetching. Use the project that has BigQuery API enabled.
GOOGLE_CLOUD_PROJECT=<your-project-id>

# Sonnet scoring goes through the local Claude Code CLI (`claude`).
# The CLI must be installed and authenticated against a Claude Max (or equivalent)
# subscription. See https://docs.anthropic.com/claude/code for installation.
# Override the binary path if needed:
# CLAUDE_BIN=/usr/local/bin/claude

# Optional overrides
# Optional: service account JSON. Prefer ADC via `gcloud auth application-default login`
# for local development, and leave this unset when ADC is already configured.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json

# Codex CLI binary (must be on PATH). Defaults to "codex".
CODEX_BIN=codex

# Codex sandbox. workspace-write is enough because we only read/write inside out/.
CODEX_SANDBOX=workspace-write

# Maximum patents to fetch per category before scoring (cost guard).
MAX_PATENTS_PER_CATEGORY=25

# Score threshold for "both models agree" cut.
SCORE_THRESHOLD=7

# Optional: Discord webhook URL for weekly notifications.
# Get it from your Discord server: Channel Settings -> Integrations -> Webhooks -> New Webhook.
# Format: https://discord.com/api/webhooks/<id>/<token>
# Without this, runs finish silently (no Discord push).
DISCORD_WEBHOOK_URL=
